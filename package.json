    "check:errors": "run-s check:ts check:es",
    "check": "run-p check:errors check:fmt",
    "format": "git diff HEAD --name-only --diff-filter d | grep -E '(js|ts|svelte)$' | xargs -r prettier --write",
    "benchmark:pqc:dm": "PQC_PRINT_BASELINE=1 vitest --run tests/unit/engine/pqc/dm-latency-benchmark.spec.ts -t 'benchmarks DM encrypt/decrypt with strict-vs-compatibility overhead output'",
    "benchmark:pqc:group": "PQC_PRINT_BASELINE=1 PQC_GROUP_BENCH_ITERATIONS=50 vitest --run tests/unit/engine/pqc/group-rekey-latency-benchmark.spec.ts -t 'captures add/remove/churn benchmark summaries'",
